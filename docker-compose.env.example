DOCKER_IMAGE_PREFIX=docker.m.daocloud.io/
NPM_REGISTRY=https://registry.npmmirror.com/
TZ=Asia/Shanghai
DOCKER_DATA_ROOT=./docker-data

HTTP_PORT=80
BACKEND_PORT=4000
BACKEND_INTERNAL_PORT=4000
NOTIFICATION_SERVICE_PORT=4101
CORE_SERVICE_PANEL_PORT=4102
CORE_SERVICE_AGENT_PORT=4103
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

DOCKER_COMPOSE_PROJECT=nanostory
NODE_ID=local-node
SERVICE_SHARED_SECRET=change-this-shared-secret
BACKEND_SERVICE_ID=backend
NOTIFICATION_SERVICE_ID=notification-service

BACKEND_UPSTREAM=http://backend:4000
NOTIFICATION_UPSTREAM=http://notification-service:4101
NOTIFICATION_SERVICE_URL=http://notification-service:4101
CORE_SERVICE_URL=http://core-service-control:4100
CORE_CONTROL_URL=http://core-service-control:4100
CORE_AGENT_BASE_URL=http://core-service-agent:4103
NOTIFICATION_PANEL_PUBLIC_URL=http://localhost:4101
CORE_SERVICE_PANEL_PUBLIC_URL=http://localhost:4102

NOTIFICATION_DISPATCH_BATCH_SIZE=100
NOTIFICATION_MAX_IN_FLIGHT_PER_SESSION=3
NOTIFICATION_LEASE_SECONDS=15

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-this-minio-password
MINIO_BUCKET=nanostory
MINIO_PUBLIC_URL=http://localhost:9000/nanostory
