# 环境变量配置示例
# 复制此文件为 .env 并修改相应的值

# ============================================
# 安全配置（必须）
# ============================================

# MySQL 数据库配置
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_DATABASE=nanostory
MYSQL_USER=your-mysql-username
MYSQL_PASSWORD=your-mysql-password



# JWT 密钥（生产环境必须设置，建议使用 32 位以上随机字符串）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# 管理后台独立访问密钥（管理员登录和所有后台接口都需要）
ADMIN_ACCESS_KEY=replace-with-a-long-random-admin-access-key

# ============================================
# CORS 配置
# ============================================

# 允许的前端域名（用逗号分隔多个域名）
# 开发环境：http://localhost:3000
# 生产环境：https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# 服务器配置
# ============================================

# 服务端口
PORT=4000

# 运行环境（development / production）
NODE_ENV=development


# ===== MinIO 文件存储 =====
# MinIO 服务地址（不含 http://）
MINIO_ENDPOINT=your-minio-endpoint
# MinIO API 端口
MINIO_PORT=9000
# 是否使用 HTTPS（生产环境建议 true）
MINIO_USE_SSL=false
# MinIO 访问密钥
MINIO_ACCESS_KEY=your-minio-access-key
# MinIO 秘密密钥
MINIO_SECRET_KEY=your-minio-secret-key
# 默认存储桶名称
MINIO_BUCKET=nanostory
# 文件访问基础 URL（用于拼接持久化文件的公开访问地址）
# 格式: http(s)://域名:端口/桶名
# 本地开发示例: http://localhost:9000/nanostory
# 生产环境示例: https://cdn.yourdomain.com/nanostory
MINIO_PUBLIC_URL=http://your-minio-endpoint:9000/nanostory


#docker run -p 9000:9000 -p 9001:9001 minio/minio server /data --console-address ":9001"


# ===== ComfyUI 配置 =====
# ComfyUI 服务地址
COMFYUI_BASE_URL=http://localhost:8188
# ComfyUI 输出目录（图片输出路径）
COMFYUI_OUTPUT_DIR=/path/to/comfyui/output
